---
import '../styles/global.css';

interface Props {
  title?: string;
}

const { title = 'Astrologia' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Astrologia - Your Astrology Learning Hub" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh flex flex-col">
    <div class="bg-celestial" aria-hidden="true"></div>
    <slot />
    <footer class="mt-auto py-6 text-center text-text-muted text-sm">
      <p>&copy; 2026 Astrologia</p>
    </footer>
  </body>
</html>
